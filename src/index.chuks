                this._random_normal_f64 = L.symbol("np_random_normal_f64",
                    new CSig([CSig.T_DOUBLE, CSig.T_DOUBLE, CSig.T_INT64, CSig.T_PTR], CSig.T_PTR))
                this._random_binomial_f64 = L.symbol("np_random_binomial_f64",
                    new CSig([CSig.T_INT64, CSig.T_DOUBLE, CSig.T_INT64, CSig.T_PTR], CSig.T_PTR))
                this._random_poisson_f64 = L.symbol("np_random_poisson_f64",
                    new CSig([CSig.T_DOUBLE, CSig.T_INT64, CSig.T_PTR], CSig.T_PTR))
                this._random_gamma_f64 = L.symbol("np_random_gamma_f64",
                    new CSig([CSig.T_DOUBLE, CSig.T_DOUBLE, CSig.T_INT64, CSig.T_PTR], CSig.T_PTR))
                this._random_beta_f64 = L.symbol("np_random_beta_f64",
