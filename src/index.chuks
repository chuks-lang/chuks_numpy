// chuks_numpy — NumPy-style n-dimensional arrays for Chuks (Phase NU0 scaffold).
//
// Builds a thin Rust cdylib shim wrapping the `ndarray` crate on first
// use via `r.cargoBuild(...)` and exposes a typed NDArray API.
//
// Scaffold surface (v0.1):
//   • NumPy        — top-level loader; exposes `version()`, `zeros(shape)`.
//   • NDArray      — owned f64 array with `shape()`, `rank()`, `len()`,
//                    `get(idx)`, `set(idx, v)`, `close()`.
//
// Phases NU1–NU5 will add:
//   • NU1 — construction (ones, full, arange, linspace, from1d/2d), reshape,
//           strided slicing, fancy indexing.
//   • NU2 — elementwise (+,-,*,/, sqrt, exp, log, sin, ...), broadcasting,
//           reductions (sum, mean, std, max, min, argmax, argmin, axis-wise).
//   • NU3 — BLAS-backed linalg (matmul, dot, solve, inv, det, svd, eig, qr,
    //           cholesky), plus FFT.
//   • NU4 — ternary kernels via the typed-FFI PPP_I fast path:
//           where(cond, x, y), select([conds], [choices]), copyto(dst, src, mask),
//           masked-assign arr[mask] = other.
//   • NU5 — IO (npy/npz read/write), random (PRNG), interop with chuks_arrow
//           (zero-copy NDArray ↔ Arrow primitive array).
//
// Usage:
//   import { NumPy } from "chuks_numpy"
//
//   const np = new NumPy()
//   println(np.version())
//
//   const a = np.zeros([2, 3])
//   a.set([0, 1], 3.14)
//   println(string(a.get([0, 1])))   // 3.14
//   a.close()

import { c, LibHandle, CFunc, CPtr, CSig } from "std/chuksToC"
import { r } from "std/chuksToRust"

// ── NDArray ─────────────────────────────────────────────────────────
//
// Owned f64 array handle. Wraps a Rust `ArrayD<f64>` via Box::into_raw.
// Always call `close()` exactly once; reuse after close is undefined.

@iterationCost("warning", "Iterating an NDArray element-by-element via .get() is ~100-1000x slower than bulk ops. Materialize once with .toFloats(), or use NumPy ufuncs (np.add/np.mul/np.dot/np.matmul) which compute in one call.", "ndarray.toFloats()  // flat row-major []float", "np.add(a, b) / np.dot(a, b)  // vectorized")
export class NDArray {
    var _ptr: CPtr
    var _np: NumPy
    var _open: bool

    constructor(ptr: CPtr, np: NumPy) {
        this._ptr = ptr
        this._np = np
        this._open = true
    }

    private __checkOpen(): void {
        if (this._open == false) {
            throw new Error("chuks_numpy: NDArray used after close()")
        }
    }

    /*
     Total number of elements (product of shape dims). Matches NumPy's
     `arr.size`.
     */
    public size(): int {
        this.__checkOpen()
        return int(this._np._arrayLen(this._ptr))
    }

    /*
     Number of dimensions. Matches NumPy's `arr.ndim`.
     */
    public ndim(): int {
        this.__checkOpen()
        return int(this._np._arrayRank(this._ptr))
    }

    /*
     Size of dimension `axis` (0-indexed). Returns -1 if axis is out of range.
     */
    public dim(axis: int): int {
        this.__checkOpen()
        return int(this._np._arrayDim(this._ptr, axis))
    }

    /*
     Element data type. Matches NumPy's `arr.dtype` (as a string).
     Always `"float64"` — chuks_numpy NDArrays are f64-only.
     */
    public dtype(): string {
        this.__checkOpen()
        return "float64"
    }

    /*
     Size in bytes of one element. Matches NumPy's `arr.itemsize`.
     Always `8` (f64).
     */
    public itemsize(): int {
        this.__checkOpen()
        return 8
    }

    /*
     Total bytes consumed by the array's elements. Matches NumPy's
     `arr.nbytes` (== size() * itemsize()).
     */
    public nbytes(): int {
        return this.size() * 8
    }

    /*
     Shape as an array of dim sizes (length == ndim()).
     */
    public shape(): []int {
        this.__checkOpen()
        const r: int = this.ndim()
        var out: []int = []
        for (var i: int = 0; i < r; i = i + 1) {
            out.push(this.dim(i))
        }
        return out
    }

    /*
     Read the element at `idxs`. Returns 0.0 if `idxs` is out of range or
     has wrong length. Length of `idxs` must equal ndim().
     */
    public get(idxs: []int): float {
        this.__checkOpen()
        const buf: CPtr = this.__idxBuf(idxs)
        const v: float = this._np._arrayGet(this._ptr, buf)
        buf.free()
        return v
    }

    /*
     Write `v` at `idxs`. Returns true on success, false if out-of-range or
     wrong-length idxs.
     */
    public set(idxs: []int, v: float): bool {
        this.__checkOpen()
        const buf: CPtr = this.__idxBuf(idxs)
        const rc: int = this._np._arraySet(this._ptr, buf, v)
        buf.free()
        return rc == 0
    }

    /*
     Copy the entire array into a flat []float in row-major (C) order.
     Length of the result equals len(). For multi-dim arrays the elements
     are laid out as if iterated by the last axis fastest.
     */
    public toFloats(): []float {
        this.__checkOpen()
        const n: int = this.size()
        if (n == 0) {
            const empty: []float = []
            return empty
        }
        const buf: CPtr = c.alloc(n * 8)
        const wrote: int = int(this._np._arrayToData(this._ptr, buf))
        const out: []float = c.readDoubleSlice(buf, wrote)
        buf.free()
        return out
    }

    /*
     Return a new NDArray with the given `shape` and the same elements
     in row-major order. The product of `shape` must equal len().
     The source array is unchanged. Throws if the product mismatches.
     */
    public reshape(shape: []int): NDArray {
        this.__checkOpen()
        return this._np.__wrapNew(
            this._np._arrayReshape(this._ptr, shape),
            "reshape: invalid shape (product must equal len())")
    }

    /*
     Return a new NDArray with the axes reversed (NumPy `.T`). For a 2-D
     array this is the matrix transpose.
     */
    public transpose(): NDArray {
        this.__checkOpen()
        return this._np.__wrapNew(
            this._np._arrayTranspose(this._ptr),
            "transpose: failed")
    }

    /*
     Return a new NDArray sliced per-axis by `[starts[i] : ends[i] : steps[i])`.
     `starts/ends/steps` must each have length == rank(). Negative
     `starts`/`ends` are normalized Python-style. `steps` must be > 0.
     Throws on shape mismatch or invalid step.
     */
    public slice(starts: []int, ends: []int, steps: []int): NDArray {
        this.__checkOpen()
        return this._np.__wrapNew(
            this._np._arraySlice(this._ptr, starts, ends, steps),
            "slice: invalid arguments")
    }

    /*
     Slice a single `axis` by `[start : stop : step)` and leave every other
     axis full. Matches NumPy `a[..., start:stop:step, ...]`.
     
     `start`/`stop` accept Python-style negative values (counted from the end
     of that axis). `step` must be > 0. Pass `start = 0` and `stop = -1` to
     mean "to the end". For an explicit "to the end" use the axis length, e.g.
     `a.sliceAxis(0, 1, a.shape()[0], 1)`.
     */
    public sliceAxis(axis: int, start: int, stop: int, step: int): NDArray {
        this.__checkOpen()
        const shp: []int = this.shape()
        const r: int = shp.length
        if (axis < 0 || axis >= r) {
            throw new Error("sliceAxis: axis " + string(axis) + " out of range for rank " + string(r))
        }
        const starts: []int = []
        const ends: []int = []
        const steps: []int = []
        for (var k: int = 0; k < r; k++) {
            if (k == axis) {
                var s: int = start
                var e: int = stop
                if (s < 0) { s = shp[k] + s }
                if (e < 0) { e = shp[k] + e + 1 }
                starts.push(s)
                ends.push(e)
                steps.push(step)
            } else {
                starts.push(0)
                ends.push(shp[k])
                steps.push(1)
            }
        }
        return this.slice(starts, ends, steps)
    }

    /*
     Slice multiple axes at once. Each key in `ranges` is an axis index; its
     value is a `[start, stop, step]` triple. Axes not mentioned are left
     full-range. Negative `start`/`stop` are normalized Python-style.
     
     Example — NumPy `a[1:5, :, 0:10:2]` becomes:
     a.sliceAxes({0: [1, 5, 1], 2: [0, 10, 2]})
     */
    public sliceAxes(ranges: map[int][]int): NDArray {
        this.__checkOpen()
        const shp: []int = this.shape()
        const r: int = shp.length
        const starts: []int = []
        const ends: []int = []
        const steps: []int = []
        for (var k: int = 0; k < r; k++) {
            if (ranges.has(k)) {
                const tripV: any = ranges.get(k)
                const trip: []int = tripV
                if (trip.length != 3) {
                    throw new Error("sliceAxes: axis " + string(k) + " expected [start, stop, step], got length " + string(trip.length))
                }
                var s: int = trip[0]
                var e: int = trip[1]
                const st: int = trip[2]
                if (s < 0) { s = shp[k] + s }
                if (e < 0) { e = shp[k] + e + 1 }
                starts.push(s)
                ends.push(e)
                steps.push(st)
            } else {
                starts.push(0)
                ends.push(shp[k])
                steps.push(1)
            }
        }
        return this.slice(starts, ends, steps)
    }

    /*
     Fancy-index along `axis`: return a new NDArray made of
     `idxs.length` slices along `axis` selected by each index.
     Out-of-range indices cause failure.
     */
    public take(axis: int, idxs: []int): NDArray {
        this.__checkOpen()
        return this._np.__wrapNew(
            this._np._arrayTake(this._ptr, axis, idxs),
            "take: invalid axis or index")
    }

    /*
     Return the i-th slice along axis 0 with that axis dropped.
     For a 2-D array this returns the i-th row (1-D, length == cols).
     For a 3-D array this returns the i-th 2-D plane. Matches NumPy
     `a[i, ...]`. Supports negative `i` (Python-style).
     
     Chains naturally with col(): `a.row(1).col(4)` on a 2-D array
     yields the 0-D scalar at row 1, column 4 — call `.item()` to
     unwrap it as a float.
     */
    public row(i: int): NDArray {
        this.__checkOpen()
        const shp: []int = this.shape()
        if (shp.length < 1) {
            throw new Error("row: cannot index a 0-D array")
        }
        var idx: int = i
        if (idx < 0) { idx = shp[0] + idx }
        // take + drop axis 0 via reshape to remaining dims
        const picked: NDArray = this.take(0, [idx])
        if (shp.length == 1) {
            // 1-D → scalar (0-D)
            const out: NDArray = picked.reshape([])
            picked.close()
            return out
        }
        const rest: []int = []
        for (var k: int = 1; k < shp.length; k++) { rest.push(shp[k]) }
        const out2: NDArray = picked.reshape(rest)
        picked.close()
        return out2
    }

    /*
     Return the j-th slice along the LAST axis with that axis dropped.
     For a 2-D array this returns the j-th column (1-D, length == rows).
     For a 1-D array this returns the j-th element as a 0-D NDArray —
     use `.item()` to read the float. Matches NumPy `a[..., j]`.
     Supports negative `j` (Python-style).
     */
    public col(j: int): NDArray {
        this.__checkOpen()
        const shp: []int = this.shape()
        const r: int = shp.length
        if (r < 1) {
            throw new Error("col: cannot index a 0-D array")
        }
        const axis: int = r - 1
        var idx: int = j
        if (idx < 0) { idx = shp[axis] + idx }
        const picked: NDArray = this.take(axis, [idx])
        if (r == 1) {
            const out: NDArray = picked.reshape([])
            picked.close()
            return out
        }
        const rest: []int = []
        for (var k: int = 0; k < axis; k++) { rest.push(shp[k]) }
        const out2: NDArray = picked.reshape(rest)
        picked.close()
        return out2
    }

    /*
     Unwrap a 0-D (scalar) NDArray as a float. Matches NumPy `arr.item()`.
     Throws if the array has more than one element.
     */
    public item(): float {
        this.__checkOpen()
        if (this.size() != 1) {
            throw new Error("item: array has " + string(this.size()) + " elements, expected 1")
        }
        const data: []float = this.toFloats()
        return data[0]
    }

    /*
     Return an independent deep copy. Mutations on the copy do not
     affect the source.
     */
    public copy(): NDArray {
        this.__checkOpen()
        return this._np.__wrapNew(
            this._np._arrayCopy(this._ptr),
            "copy: failed")
    }

    /*
     Release the Rust-side allocation. Calling close() more than once is a no-op.
     */
    public close(): void {
        if (this._open) {
            this._np._freeArray(this._ptr)
            this._open = false
        }
    }

    /*
     NumPy-style pretty-print of the array. Works for any rank.
     Examples:
     1-D : [1, 2, 3.3]
     2-D : [[7, 8],
     [9, 10],
     [11, 12]]
     For rank >= 3 the printout is nested with one extra level of indent per axis.
     Use this when calling println(a) — Chuks's default println falls back to
     "Instance(NDArray)" for class instances, so call println(a.toString()).
     */
    public toString(): string {
        this.__checkOpen()
        const shp: []int = this.shape()
        const flat: []float = this.toFloats()
        if (shp.length == 0) {
            return "[]"
        }
        return this.__fmtNd(shp, flat, 0, 0, 1)
    }

    // Recursive NumPy-style formatter. `axis` is the current dim being
    // expanded, `offset` is the start of the current sub-array in the flat
    // row-major buffer, `indent` is the column where "[" sits (used to align
            // sub-rows of multi-dim arrays).
        private __fmtNd(shape: []int, flat: []float, axis: int, offset: int, indent: int): string {
            const rank: int = shape.length
            // Innermost axis: emit "[a, b, c]" on a single line.
            if (axis == rank - 1) {
                const n: int = shape[axis]
                var s: string = "["
                    for (var i: int = 0; i < n; i = i + 1) {
                        if (i > 0) { s = s + ", " }
                        s = s + string(flat[offset + i])
                    }
                    return s + "]"
            }
            // Outer axes: stride across remaining dims, separate children with
            // ",\n" + indentation so columns of sub-arrays line up under the "[".
                var stride: int = 1
                for (var k: int = axis + 1; k < rank; k = k + 1) {
                    stride = stride * shape[k]
                }
                var pad: string = ""
                for (var p: int = 0; p < indent; p = p + 1) {
                    pad = pad + " "
                }
                var s: string = "["
                    const n: int = shape[axis]
                    for (var i: int = 0; i < n; i = i + 1) {
                        if (i > 0) { s = s + ",\n" + pad }
                        s = s + this.__fmtNd(shape, flat, axis + 1, offset + i * stride, indent + 1)
                    }
                    return s + "]"
            }

            // ── NU2: Elementwise binary ops (broadcasting) ─────────────────
            // Each op returns a new NDArray; the receiver is unchanged.
            // For scalar arguments use the `*Scalar` variants below.

            public add(other: NDArray): NDArray { return this.__bin(other, 0) }
            public sub(other: NDArray): NDArray { return this.__bin(other, 1) }
            public mul(other: NDArray): NDArray { return this.__bin(other, 2) }
            public div(other: NDArray): NDArray { return this.__bin(other, 3) }
            public pow(other: NDArray): NDArray { return this.__bin(other, 4) }
            public modulo(other: NDArray): NDArray { return this.__bin(other, 5) }
            public minimum(other: NDArray): NDArray { return this.__bin(other, 6) }
            public maximum(other: NDArray): NDArray { return this.__bin(other, 7) }

            public addScalar(v: float): NDArray { return this.__binS(v, 0, 0) }
            public subScalar(v: float): NDArray { return this.__binS(v, 1, 0) }
            public mulScalar(v: float): NDArray { return this.__binS(v, 2, 0) }
            public divScalar(v: float): NDArray { return this.__binS(v, 3, 0) }
            public powScalar(v: float): NDArray { return this.__binS(v, 4, 0) }
            public modScalar(v: float): NDArray { return this.__binS(v, 5, 0) }
            public minScalar(v: float): NDArray { return this.__binS(v, 6, 0) }
            public maxScalar(v: float): NDArray { return this.__binS(v, 7, 0) }

            // Reversed-scalar forms (scalar OP arr), useful for sub/div/pow/mod.
            public rsubScalar(v: float): NDArray { return this.__binS(v, 1, 1) }
            public rdivScalar(v: float): NDArray { return this.__binS(v, 3, 1) }
            public rpowScalar(v: float): NDArray { return this.__binS(v, 4, 1) }
            public rmodScalar(v: float): NDArray { return this.__binS(v, 5, 1) }

            // ── NU2: Unary elementwise ─────────────────────────────────────

            public sqrt(): NDArray { return this.__un(0) }
            public exp(): NDArray { return this.__un(1) }
            public log(): NDArray { return this.__un(2) }
            public sin(): NDArray { return this.__un(3) }
            public cos(): NDArray { return this.__un(4) }
            public tan(): NDArray { return this.__un(5) }
            public abs(): NDArray { return this.__un(6) }
            public floor(): NDArray { return this.__un(7) }
            public ceil(): NDArray { return this.__un(8) }
            public round(): NDArray { return this.__un(9) }
            public neg(): NDArray { return this.__un(10) }

            // ── NU2: Comparisons (return a 0.0/1.0 NDArray mask) ───────────

            public eq(other: NDArray): NDArray { return this.__cmp(other, 0) }
            public ne(other: NDArray): NDArray { return this.__cmp(other, 1) }
            public lt(other: NDArray): NDArray { return this.__cmp(other, 2) }
            public le(other: NDArray): NDArray { return this.__cmp(other, 3) }
            public gt(other: NDArray): NDArray { return this.__cmp(other, 4) }
            public ge(other: NDArray): NDArray { return this.__cmp(other, 5) }

            public eqScalar(v: float): NDArray { return this.__cmpS(v, 0, 0) }
            public neScalar(v: float): NDArray { return this.__cmpS(v, 1, 0) }
            public ltScalar(v: float): NDArray { return this.__cmpS(v, 2, 0) }
            public leScalar(v: float): NDArray { return this.__cmpS(v, 3, 0) }
            public gtScalar(v: float): NDArray { return this.__cmpS(v, 4, 0) }
            public geScalar(v: float): NDArray { return this.__cmpS(v, 5, 0) }

            // ── NU2: Reductions ────────────────────────────────────────────
            // All-axes reductions return a float; per-axis reductions return an
            // NDArray. `keepdims` preserves the reduced axis as size 1.

            public sum(): float { return this.__red(0) }
            public mean(): float { return this.__red(1) }
            public min(): float { return this.__red(2) }
            public max(): float { return this.__red(3) }
            public prod(): float { return this.__red(4) }
            public std(): float { return this.__red(5) }
            public variance(): float { return this.__red(6) }
            public any(): bool { return this.__red(7) != 0.0 }
            public all(): bool { return this.__red(8) != 0.0 }
            public argmin(): int { return int(this.__red(9)) }
            public argmax(): int { return int(this.__red(10)) }

            public sumAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 0) }
            public meanAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 1) }
            public minAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 2) }
            public maxAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 3) }
            public prodAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 4) }
            public stdAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 5) }
            public varAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 6) }
            public anyAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 7) }
            public allAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 8) }
            public argminAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 9) }
            public argmaxAxis(axis: int, keepdims: bool): NDArray { return this.__redAx(axis, keepdims, 10) }

            // ── NU2: In-place binary ops (mutate this) ─────────────────────
            // `other` must broadcast to this.shape(). Returns this (for chaining).

            public addInPlace(other: NDArray): NDArray { return this.__binIp(other, 0) }
            public subInPlace(other: NDArray): NDArray { return this.__binIp(other, 1) }
            public mulInPlace(other: NDArray): NDArray { return this.__binIp(other, 2) }
            public divInPlace(other: NDArray): NDArray { return this.__binIp(other, 3) }

            public addInPlaceScalar(v: float): NDArray { return this.__binIpS(v, 0) }
            public subInPlaceScalar(v: float): NDArray { return this.__binIpS(v, 1) }
            public mulInPlaceScalar(v: float): NDArray { return this.__binIpS(v, 2) }
            public divInPlaceScalar(v: float): NDArray { return this.__binIpS(v, 3) }

            // ── NU2 internals ──────────────────────────────────────────────

            private __bin(other: NDArray, op: int): NDArray {
                this.__checkOpen()
                return this._np.__wrapNew(
                    this._np._binop(this._ptr, other._ptr, op),
                    "binary op failed (incompatible shapes?)")
            }

            private __binS(v: float, op: int, rev: int): NDArray {
                this.__checkOpen()
                return this._np.__wrapNew(
                    this._np._binopScalar(this._ptr, v, op, rev),
                    "scalar binary op failed")
            }

            private __un(op: int): NDArray {
                this.__checkOpen()
                return this._np.__wrapNew(
                    this._np._unary(this._ptr, op),
                    "unary op failed")
            }

            private __cmp(other: NDArray, op: int): NDArray {
                this.__checkOpen()
                return this._np.__wrapNew(
                    this._np._cmp(this._ptr, other._ptr, op),
                    "compare failed (incompatible shapes?)")
            }

            private __cmpS(v: float, op: int, rev: int): NDArray {
                this.__checkOpen()
                return this._np.__wrapNew(
                    this._np._cmpScalar(this._ptr, v, op, rev),
                    "scalar compare failed")
            }

            private __red(op: int): float {
                this.__checkOpen()
                return this._np._reduceAll(this._ptr, op)
            }

            private __redAx(axis: int, keepdims: bool, op: int): NDArray {
                this.__checkOpen()
                var k: int = 0
                if (keepdims) { k = 1 }
                return this._np.__wrapNew(
                    this._np._reduceAxis(this._ptr, axis, k, op),
                    "reduce-axis failed (invalid axis?)")
            }

            private __binIp(other: NDArray, op: int): NDArray {
                this.__checkOpen()
                const rc: int = this._np._binopInplace(this._ptr, other._ptr, op)
                if (rc != 0) {
                    throw new Error("chuks_numpy: in-place binary op failed (shapes not broadcast-compatible)")
                }
                return this
            }

            private __binIpS(v: float, op: int): NDArray {
                this.__checkOpen()
                this._np._binopInplaceScalar(this._ptr, v, op)
                return this
            }

            private __idxBuf(idxs: []int): CPtr {
                const n: int = idxs.length
                var alloc: int = n * 8
                if (alloc == 0) { alloc = 1 }
                const buf: CPtr = c.alloc(alloc)
                if (n > 0) {
                    // Normalize negative indices Python/NumPy-style: -1 == last,
                    // -2 == second-to-last along that axis, etc. Out-of-range
                    // values are passed through and rejected by the shim.
                    var normalized: []int = idxs
                    var hasNegative: bool = false
                    for (var i: int = 0; i < n; i++) {
                        if (idxs[i] < 0) { hasNegative = true; break }
                    }
                    if (hasNegative) {
                        const shp: []int = this.shape()
                        const sn: int = shp.length
                        normalized = []
                        for (var i: int = 0; i < n; i++) {
                            var v: int = idxs[i]
                            if (v < 0 && i < sn) {
                                v = shp[i] + v
                            }
                            normalized.push(v)
                        }
                    }
                    c.writeInt64Slice(buf, normalized)
                }
                return buf
            }
        }

        // ── NumPy ───────────────────────────────────────────────────────────
        //
        // Top-level loader. Holds the loaded shim library and cached CFunc
        // handles. One instance per process is recommended.

        export class NumPy {
            var _lib: LibHandle

            // Strings
            var _version_fn: CFunc
            var _free_string: CFunc

            // NDArray (f64)
            var _array_zeros_f64: CFunc
