                this._random_choice_f64 = L.symbol("np_random_choice_f64",
                    new CSig([CSig.T_PTR, CSig.T_INT64, CSig.T_INT], CSig.T_PTR))
                this._random_shuffle_f64 = L.symbol("np_random_shuffle_f64",
                    new CSig([CSig.T_PTR], CSig.T_INT))

                // NU5 NPY / NPZ IO
                this._save_npy = L.symbol("np_save_npy",
                    new CSig([CSig.T_PTR, CSig.T_CSTRING], CSig.T_INT))
                this._load_npy = L.symbol("np_load_npy",
                    new CSig([CSig.T_CSTRING], CSig.T_PTR))
                this._npz_writer_open = L.symbol("np_npz_writer_open",
                    new CSig([CSig.T_CSTRING], CSig.T_PTR))
                this._npz_writer_add = L.symbol("np_npz_writer_add",
                    new CSig([CSig.T_PTR, CSig.T_CSTRING, CSig.T_PTR], CSig.T_INT))
                this._npz_writer_close = L.symbol("np_npz_writer_close",
                    new CSig([CSig.T_PTR], CSig.T_INT))
                this._npz_reader_open = L.symbol("np_npz_reader_open",
                    new CSig([CSig.T_CSTRING], CSig.T_PTR))
                this._npz_reader_count = L.symbol("np_npz_reader_count",
                    new CSig([CSig.T_PTR], CSig.T_INT64))
